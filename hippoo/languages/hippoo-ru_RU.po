msgid "Chat GPT"
msgstr "ChatGPT"

#: app/ai.php:151
msgid "Gemini"
msgstr "Gemini"

#: app/ai.php:192
msgid "Enter your API key"
msgstr "Введите ваш API-ключ"

#: app/ai.php:193
msgid "How can I provide the token?"
msgstr "Как предоставить токен?"

#: app/ai.php:195
msgid "Test connection"
msgstr "Проверить соединение"

#: app/ai.php:202
msgid "AI Product Reader"
msgstr "Сканер товаров с ИИ"

#: app/ai.php:204
msgid "Prompt settings"
msgstr "Настройки промптов"

#: app/ai.php:205
msgid "Customize how the AI generates text by editing the prompts below. Each prompt guides the AI to produce the desired type of content for your products. You can adjust these to change tone, style, or structure of the generated descriptions."
msgstr "Настройте способ генерации текста ИИ, редактируя промпты ниже. Каждый промпт направляет ИИ на создание нужного типа контента для ваших товаров. Вы можете изменять тон, стиль или структуру сгенерированных описаний."

#: app/ai.php:216
msgid "Sets the general behavior or role of the AI (e.g., “You are a product description writer for an online store.)"
msgstr "Задаёт общее поведение или роль ИИ (например: «Ты — автор описаний товаров для интернет-магазина».)"

#: app/ai.php:228
msgid "Defines how the main product description should be written (e.g., length, tone, structure)"
msgstr "Определяет, как должна быть написана основная описание товара (например: длина, тон, структура)"

#: app/ai.php:252
#: app/ai.php:366
#: app/ai.php:439
msgid "You haven’t provided an API key. Please go to the Hippoo settings page and add your API key to connect to the AI."
msgstr "Вы не указали API-ключ. Перейдите на страницу настроек Hippoo и добавьте ваш API-ключ, чтобы подключиться к ИИ."

