#. Plugin Name of the plugin
#: hippoo.php
msgid "Hippoo Mobile app for WooCommerce"
msgstr "Мобильное приложение Hippoo для WooCommerce"

#. Plugin URI of the plugin
#. Author URI of the plugin
#: hippoo.php
msgid "https://Hippoo.app/"
msgstr "https://hippoo.app/"

#. Description of the plugin
#: hippoo.php
msgid "Best WooCommerce App Alternative – Manage orders and products on the go with real-time notifications, seamless order and product management, and powerful add-ons. Available for Android & iOS. 🚀."
msgstr "Лучшая альтернатива приложению WooCommerce — управляйте заказами и товарами на ходу с мгновенными уведомлениями, удобным управлением заказами и товарами и мощными дополнениями. Доступно для Android и iOS. 🚀"

#. Author of the plugin
#: hippoo.php
msgid "Hippoo Team"
msgstr "Команда Hippoo"

